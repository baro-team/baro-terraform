aws_region  = "ap-northeast-2"
project     = "baro"
environment = "dev"

# Restrict this to your IP in real dev environments.
allowed_http_cidrs = ["0.0.0.0/0"]

domain_name     = "barocloud.com"
app_domain_name = "dev.barocloud.com"

# CI pushes :latest by default and forces a new ECS deployment.
image_tag = "latest"

service_desired_count = 1
service_cpu           = 512
service_memory        = 1024

rds_instance_class    = "db.t4g.micro"
rds_engine_version    = "16"
rds_allocated_storage = 20
rds_database_name     = "baro"
rds_master_username   = "baroadmin"

# Start API traffic through gateway-service.
# Add frontend services later, for example: ["gateway", "user", "dispatch", "relocation", "control", "mobile", "admin"]
enabled_services = ["gateway", "user", "dispatch"]

service_desired_counts = {
  gateway  = 1
  user     = 1
  dispatch = 1
}

# Optional plain environment overrides, by service key: gateway, control, dispatch, relocation, user.
service_environment = {
  control = {
    # DISPATCH_SERVICE_URL is modeled as a secret by default.
  }
}

# Existing Secrets Manager secret used by /internal/** API receivers.
internal_api_key_secret_name = "baro-dev/dispatch/INTERNAL_API_KEY"
